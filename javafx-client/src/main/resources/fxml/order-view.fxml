<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.csis231.javafxclient.controller.OrderController">

    <top>
        <VBox spacing="10" style="-fx-padding: 15px;">
            <Label text="Order Management" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

            <HBox spacing="10">
                <Label text="Order Number:" minWidth="120"/>
                <TextField fx:id="orderNumberField" prefWidth="200"/>

                <Label text="Customer Name:" minWidth="120"/>
                <TextField fx:id="customerNameField" prefWidth="200"/>
            </HBox>

            <HBox spacing="10">
                <Label text="Total Amount:" minWidth="120"/>
                <TextField fx:id="totalAmountField" prefWidth="200"/>
            </HBox>

            <HBox spacing="10">
                <Button text="Create" onAction="#createOrder"/>
                <Button text="Update" onAction="#updateOrder"/>
                <Button text="Delete" onAction="#deleteOrder"/>
                <Button text="Refresh" onAction="#loadOrders"/>
            </HBox>

            <Label fx:id="statusLabel" text="Ready"/>
        </VBox>
    </top>

    <center>
        <VBox>
            <TableView fx:id="orderTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="80"/>
                    <TableColumn fx:id="orderNumberColumn" text="Order Number" prefWidth="200"/>
                    <TableColumn fx:id="customerNameColumn" text="Customer Name" prefWidth="200"/>
                    <TableColumn fx:id="totalAmountColumn" text="Total Amount" prefWidth="150"/>
                </columns>
            </TableView>
        </VBox>
    </center>

</BorderPane>