<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.csis231.javafxclient.controller.LoginController">
    <top>
        <Label text="User Authentication"
               style="-fx-font-size: 20px; -fx-font-weight: bold ; -fx-padding: 10px;"/>
    </top>
    <center>
        <VBox spacing="15" alignment="CENTER" style="-fx-padding: 20px;">
            <HBox spacing="10" alignment="CENTER">
                <Label text="Username:" minWidth="100"/>
                <TextField fx:id="usernameField" prefWidth="200"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER">
                <Label text="Password:" minWidth="100"/>
                <PasswordField fx:id="passwordField" prefWidth="200"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER">
                <Button text="Login" onAction="#handleLogin"/>
            </HBox>

            <Label fx:id="statusLabel" text="Please login"/>
        </VBox>
    </center>
</BorderPane>
