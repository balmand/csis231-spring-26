<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.csis231.javafxclient.controller.UsersSearchController"
      spacing="10" padding="10">

    <HBox spacing="10">
        <Label text="Search:"/>
        <TextField fx:id="queryField" promptText="username or email" HBox.hgrow="ALWAYS"/>

        <Label text="Sort:"/>
        <ComboBox fx:id="sortFieldCombo" prefWidth="120"/>
        <ComboBox fx:id="sortDirCombo" prefWidth="90"/>

        <Label text="Page size:"/>
        <ComboBox fx:id="pageSizeCombo" prefWidth="90"/>

        <Button fx:id="searchButton" text="Search" onAction="#onSearch"/>
        <Button fx:id="clearButton" text="Clear" onAction="#onClear"/>
    </HBox>

    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="80"/>
            <TableColumn fx:id="usernameColumn" text="Username" prefWidth="200"/>
            <TableColumn fx:id="emailColumn" text="Email" prefWidth="300"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="prevButton" text="Prev" onAction="#onPrev"/>
        <Button fx:id="nextButton" text="Next" onAction="#onNext"/>
        <Label fx:id="pageLabel" text="Page 0 of 0"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusLabel" text=""/>
    </HBox>
</VBox>

