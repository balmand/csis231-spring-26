<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.csis231.javafxclient.controller.ItemController">
    <top>
        <VBox spacing="10" style="-fx-padding: 15px;">
            <Label text="Item Management" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <HBox spacing="10">
                <Label text="Name:" minWidth="100"/>
                <TextField fx:id="nameField" prefWidth="200"/>
                <Label text="Category:" minWidth="100"/>
                <TextField fx:id="categoryField" prefWidth="200"/>
            </HBox>
            <HBox spacing="10">
                <Label text="Status:" minWidth="100"/>
                <TextField fx:id="statusField" prefWidth="200"/>
            </HBox>
            <HBox spacing="10">
                <Button fx:id="createButton" text="Create" onAction="#createItem"/>
                <Button fx:id="updateButton" text="Update" onAction="#updateItem" disable="true"/>
                <Button fx:id="deleteButton" text="Delete" onAction="#deleteItem" disable="true"/>
                <Button fx:id="refreshButton" text="Refresh" onAction="#refreshItem"/>
            </HBox>
            <Label fx:id="statusLabel" text="Ready"/>
        </VBox>
    </top>
    <center>
        <VBox>
            <TableView fx:id="itemTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="nameColumn" text="Name" prefWidth="150"/>
                    <TableColumn fx:id="serialNumberColumn" text="SerialNumber" prefWidth="200"/>
                    <TableColumn fx:id="categoryColumn" text="Category" prefWidth="150"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="150"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
